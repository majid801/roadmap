{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "subscription": { "type": "string", "enum": ["free", "pro"] },
        "stripeCustomerId": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Roadmap": {
      "title": "Roadmap",
      "description": "AI-generated career roadmap",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "goal": { "type": "string" },
        "level": { "type": "string" },
        "time": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "phases": { "type": "array" },
        "progress": { "type": "number" },
        "completedTasks": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "goal", "phases"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/roadmaps/{roadmapId}": {
      "schema": "Roadmap",
      "description": "Career roadmap document"
    }
  }
}
